# FeedbackHub — Production Environment Variables
# Copy this file to .env and fill in the values.

# --- Required ---
# PostgreSQL connection string (includes credentials)
DATABASE_URL=postgres://feedback:REPLACE_ME@postgres:5432/feedback

# --- Database (optional, defaults shown) ---
# POSTGRES_USER=feedback
# POSTGRES_DB=feedback
POSTGRES_PASSWORD=REPLACE_ME

# --- Rate Limiting (optional) ---
# RATE_LIMIT_PER_MINUTE=60

# --- Frontend (optional) ---
# FRONTEND_BASE_URL=https://feedback.dreamful.life

# --- SMTP / Email Notifications (optional, skip to disable) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@feedback.dreamful.life
# SMTP_FROM_NAME=ThenApp Feedback
