http://feedback.dreamful.life {
    # API proxy to Rust backend
    handle_path /api/* {
        reverse_proxy backend:3000
    }
    handle_path /v1/* {
        reverse_proxy backend:3000
    }

    # Privacy policy static page
    handle_path /privacy/* {
        root * /static/privacy
        file_server
    }
    redir /privacy /privacy/

    # SPA — serve frontend nginx
    handle {
        reverse_proxy frontend:80
    }

    # Logging
    log {
        output file /data/access.log
    }
}
